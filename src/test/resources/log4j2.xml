<?xml version="1.0" encoding="UTF-8"?>
<Configuration>

	<appenders>
		<Console name="Console" target="SYSTEM_OUT">
			<PatternLayout pattern="%d{DD-MM-YYYY HH:mm:SS} [%t] %logger::%M::%L %highlight{%5p} %c{1}::%M():%L - %m%n"></PatternLayout>
		</Console>

		<File name="FileLogger" fileName="logs/automation.log" append="false">
			<PatternLayout pattern="%d{DD-MM-YYYY HH:mm:SS} [%t] %highlight{%5p} %c{1}::%M():%L - %m%n"></PatternLayout>
		</File>
	</appenders>

	<loggers>
		<root level="info">
			<AppenderRef ref="Console"></AppenderRef>
			<AppenderRef ref="FileLogger"></AppenderRef>


		</root>

	</loggers>
</Configuration>